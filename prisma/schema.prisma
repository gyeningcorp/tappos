generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Multi-tenant ────────────────────────────────────────

model Tenant {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  stripeAccountId  String?
  stripeCustomerId String?
  subscriptionId   String?
  plan             Plan     @default(STARTER)
  onboardingStep   Int      @default(0)
  isActive         Boolean  @default(false)
  referredByCode   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users      User[]
  products   Product[]
  categories Category[]
  orders     Order[]
  coupons    Coupon[]
  alerts     InventoryAlert[]
}

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  role           Role      @default(CASHIER)
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
  partner  Partner?

  @@index([tenantId])
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  PARTNER
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Products & Inventory ────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  sortOrder Int      @default(0)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int      // stored in cents
  image       String?
  sku         String?
  barcode     String?
  stock       Int      @default(0)
  lowStockAt  Int      @default(5)
  trackStock  Boolean  @default(true)
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants   Variant[]
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([categoryId])
}

model Variant {
  id        String   @id @default(cuid())
  name      String   // e.g., "Large", "Red"
  type      String   // e.g., "Size", "Color"
  price     Int?     // override price, null = use product price
  stock     Int      @default(0)
  sku       String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([productId])
}

// ─── Orders & Payments ───────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  subtotal      Int         // cents
  discount      Int         @default(0) // cents
  tax           Int         @default(0) // cents
  total         Int         // cents
  paymentMethod PaymentMethod
  stripePaymentId String?
  cashReceived  Int?        // cents
  changeGiven   Int?        // cents
  note          String?
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  couponId      String?
  coupon        Coupon?     @relation(fields: [couponId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD
  CASH
  TAP
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Int      // cents, price at time of sale
  name      String   // product name at time of sale
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ─── Coupons ─────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  code        String
  type        DiscountType
  value       Int        // percentage or cents depending on type
  minOrder    Int?       // minimum order in cents
  maxUses     Int?
  usedCount   Int        @default(0)
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  orders Order[]

  @@unique([code, tenantId])
  @@index([tenantId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Partners (ISO) ─────────────────────────────────────

model Partner {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  phone          String
  referralCode   String        @unique
  commissionRate Decimal       @default(15.00)
  status         PartnerStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ─── Inventory Alerts ────────────────────────────────────

model InventoryAlert {
  id         String   @id @default(cuid())
  productName String
  productId  String
  currentStock Int
  threshold  Int
  isRead     Boolean  @default(false)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([tenantId])
}
